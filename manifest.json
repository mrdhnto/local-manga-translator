{
  "manifest_version": 3,
  "name": "Local Manga Translator",
  "version": "0.1.0",
  "description": "Translate manga images using a local LLM API. Detects manga panels, extracts text, and overlays translations.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:*/*",
    "http://localhost:*/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon48.png",
      "48": "icons/icon48.png",
      "128": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon48.png",
    "48": "icons/icon48.png",
    "128": "icons/icon48.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/cc-wild-words/cc-wild-words.ttf",
        "fonts/komika/KOMIKAH_.ttf"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
